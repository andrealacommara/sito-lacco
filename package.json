{
  "name": "vite-template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "postbuild": "node scripts/generate-og-images.js && node scripts/generate-og-events.mjs && node scripts/prerender.mjs && node scripts/generate-llms.mjs && node scripts/make-presskit-zip.js",
    "preview": "vite preview",
    "lint": "eslint --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "type-check": "tsc --noEmit",
    "test:env": "node scripts/checkEnv.js",
    "test:full": "npm run lint && npm run type-check && npm run build && npm run test:env && npm run test:smoke",
    "update": "npx npm-check-updates -u && npm install",
    "test:smoke": "node scripts/smoke-test.js",
    "generate-email-assets": "node scripts/generate-email-assets.mjs"
  },
  "dependencies": {
    "@heroui/react": "^3.2.1",
